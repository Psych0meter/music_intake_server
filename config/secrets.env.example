# Copy to config/secrets.env (mode 600, owned by musicintake), fill in,
# then: systemctl restart music-recognize.service

# Required for AcoustID/MusicBrainz lookups - free, register at:
# https://acoustid.org/my-applications
ACOUSTID_API_KEY=

# Optional - only used by the lyrics-transcription fallback (fires when
# SongRec and AcoustID both find nothing at all). Free, register at:
# https://genius.com/api-clients
# Requires `pip install faster-whisper` in the venv as well.
GENIUS_ACCESS_TOKEN=
